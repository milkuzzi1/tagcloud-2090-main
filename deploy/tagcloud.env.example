# Конфиг рантайма. Положить в /etc/tagcloud/tagcloud.env (chmod 600, owner tagcloud).
# Подключается через EnvironmentFile= в tagcloud.service.

# --- Postgres ---
DATABASE_URL=postgres://tagcloud:CHANGE_ME@localhost:5432/tagcloud

# Размер пула на инстанс. По дефолту 20.
# Расчёт: postgres max_connections=100 (по умолчанию) − ~10 для админа/cron
# = ~90 свободных. На N инстансов ставим N×PG_POOL_MAX ≤ 90.
# Для 4 инстансов оптимально 20 (4×20=80). Для 1 инстанса можно 50.
PG_POOL_MAX=20
# Сколько секунд простаивающее соединение остаётся в пуле, прежде чем
# postgres-js его закроет. 20с — баланс между переоткрытиями и удержанием
# слотов в БД при низком трафике.
PG_IDLE_TIMEOUT_SEC=20
PG_CONNECT_TIMEOUT_SEC=5

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- SMTP (локальный self-host mail-сервер на 2090.fun) ---
# Один сервер: фронт + API + почта. App ходит на loopback, Postfix доверяет
# 127.0.0.0/8 (mynetworks) и сам подписывает исходящее DKIM-ом + релеит.
# Auth не нужен — SMTP_USER/SMTP_PASSWORD оставляем пустыми.
# Развёртывание Postfix + OpenDKIM + DNS см. deploy/mail-server.md.
SMTP_HOST=127.0.0.1
SMTP_PORT=25
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Tagcloud <noreply@2090.fun>"

# Альтернатива №1 — submission на свой mail-сервер с TLS+auth (если app
# и mail на разных машинах):
#   SMTP_HOST=mail.2090.fun
#   SMTP_PORT=587
#   SMTP_SECURE=false        # STARTTLS
#   SMTP_USER=app@2090.fun
#   SMTP_PASSWORD=CHANGE_ME
#
# Альтернатива №2 — внешний провайдер (Yandex/Mailgun/SES) на 465 implicit TLS:
#   SMTP_HOST=smtp.example.com
#   SMTP_PORT=465
#   SMTP_SECURE=true
#   SMTP_USER=…
#   SMTP_PASSWORD=…

# --- Runtime ---
NODE_ENV=production
PORT=3000
HOST=127.0.0.1
ORIGIN=https://yourdomain.tld

# Размер libuv thread-pool. По умолчанию у Node 4 — этого мало под параллельный
# bcrypt (cost=11 ≈ 100ms на хеш блокирует один воркер). Поднимаем до 16,
# чтобы пик логинов/регистраций не упирался в очередь воркеров.
UV_THREADPOOL_SIZE=16

# Trust X-Forwarded-* от Caddy (он на localhost, поэтому 1 хоп).
ADDRESS_HEADER=X-Forwarded-For
PROTOCOL_HEADER=X-Forwarded-Proto
XFF_DEPTH=1

# --- Логирование ---
# debug | info | warn | error | fatal. По умолчанию info в production.
LOG_LEVEL=info

# --- Метрики ---
# Bearer-токен для /metrics. Если пусто — endpoint открыт (надеемся на ACL Caddy).
# Сгенерировать: `openssl rand -hex 32`.
METRICS_TOKEN=
