# Конфиг рантайма. Положить в /etc/tagcloud/tagcloud.env (chmod 600, owner tagcloud).
# Подключается через EnvironmentFile= в tagcloud.service.

# --- Postgres ---
DATABASE_URL=postgres://tagcloud:CHANGE_ME@127.0.0.1:5432/tagcloud

# Размер пула соединений. 20 с запасом для одного инстанса (postgres по
# умолчанию держит max_connections=100).
PG_POOL_MAX=20
# Сколько секунд простаивающее соединение остаётся в пуле, прежде чем
# postgres-js его закроет.
PG_IDLE_TIMEOUT_SEC=20
PG_CONNECT_TIMEOUT_SEC=5

# --- Redis ---
REDIS_URL=redis://127.0.0.1:6379/0

# --- SMTP (SendPulse) ---
# Все письма (verification, итоги опросов) уходят через SendPulse SMTP.
# Подготовка:
#   1. Зарегистрироваться на https://sendpulse.com и включить SMTP в кабинете.
#   2. Добавить и верифицировать домен отправителя (SPF/DKIM).
#   3. В Settings → SMTP взять логин (email от аккаунта) и SMTP-пароль.
#   4. Подставить логин в SMTP_USER, пароль — в SMTP_PASSWORD.
#
# SMTP_FROM должен быть verified sender/domain в SendPulse.
#
# Лимиты SendPulse зависят от тарифа. Подробнее: https://sendpulse.com/prices
SMTP_HOST=smtp-pulse.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=CHANGE_ME_SMTP_USER
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM="Tagcloud <noreply@2090.fun>"

# Альтернативные порты:
#   SMTP_PORT=2525                    # если 587 заблокирован хостером
#   SMTP_PORT=465 + SMTP_SECURE=true  # implicit TLS

# --- ВРЕМЕННЫЙ kill switch подтверждения email ---
# AUTH_DISABLE_EMAIL_VERIFICATION=true
#
# Включайте только если SMTP физически недоступен (например, провайдер
# заблокировал исходящий 465/587 и саппорт ещё не разблокировал порт).
# В этом режиме регистрация сразу создаёт сессию и НЕ дёргает SMTP, а
# пользователи помечаются `email_verified=true` без письма. ОБЯЗАТЕЛЬНО
# снимайте флаг сразу после восстановления почты: без подтверждения email
# любой может зарегистрироваться на чужой адрес и сразу получить сессию.
# AUTH_DISABLE_EMAIL_VERIFICATION=false

# --- Runtime ---
NODE_ENV=production
PORT=3000
HOST=127.0.0.1
ORIGIN=https://cloud.2090.fun
# Публичный базовый URL для ссылок в письмах (верификация, сброс пароля).
# Если не задан — берётся ORIGIN. В проде ОБЯЗАН быть задан один из них.
PUBLIC_BASE_URL=https://cloud.2090.fun

# Размер libuv thread-pool. По умолчанию у Node 4 — этого мало под параллельный
# bcrypt (cost=11 ≈ 100ms на хеш блокирует один воркер). Поднимаем до 16,
# чтобы пик логинов/регистраций не упирался в очередь воркеров.
UV_THREADPOOL_SIZE=16

# Trust X-Forwarded-* от Caddy (он на localhost, поэтому 1 хоп).
ADDRESS_HEADER=X-Forwarded-For
PROTOCOL_HEADER=X-Forwarded-Proto
XFF_DEPTH=1

# --- Логирование ---
# debug | info | warn | error | fatal. По умолчанию info в production.
LOG_LEVEL=info

# --- Метрики ---
# Bearer-токен для /metrics. Если пусто — endpoint fail-closed (отдаёт 404).
# Сгенерировать: `openssl rand -hex 32`.
METRICS_TOKEN=
