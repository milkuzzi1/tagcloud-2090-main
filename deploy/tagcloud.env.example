# Конфиг рантайма. Положить в /etc/tagcloud/tagcloud.env (chmod 600, owner tagcloud).
# Подключается через EnvironmentFile= в tagcloud.service.

# --- Postgres ---
DATABASE_URL=postgres://tagcloud:CHANGE_ME@localhost:5432/tagcloud

# Размер пула на инстанс. По дефолту 20.
# Расчёт: postgres max_connections=100 (по умолчанию) − ~10 для админа/cron
# = ~90 свободных. На N инстансов ставим N×PG_POOL_MAX ≤ 90.
# Для 4 инстансов оптимально 20 (4×20=80). Для 1 инстанса можно 50.
PG_POOL_MAX=20
# Сколько секунд простаивающее соединение остаётся в пуле, прежде чем
# postgres-js его закроет. 20с — баланс между переоткрытиями и удержанием
# слотов в БД при низком трафике.
PG_IDLE_TIMEOUT_SEC=20
PG_CONNECT_TIMEOUT_SEC=5

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- SMTP (Sender.net) ---
# Все письма (verification, итоги опросов) уходят через Sender.net SMTP.
# Подготовка:
#   1. Зарегистрироваться на https://www.sender.net и активировать Transactional emails.
#   2. Добавить и верифицировать домен отправителя.
#   3. Создать SMTP-пользователя: Transactional emails → Setup instructions → SMTP → Add SMTP user.
#   4. Подставить логин в SMTP_USER, пароль — в SMTP_PASSWORD.
#
# SMTP_FROM должен быть verified sender/domain в Sender.net.
#
# Лимиты Sender.net зависят от тарифа. Подробнее: https://www.sender.net/pricing
SMTP_HOST=smtp.sender.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=CHANGE_ME_SMTP_USER
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM="Tagcloud <noreply@yourdomain.tld>"

# Альтернативный порт (если 587 заблокирован хостером):
#   SMTP_PORT=2525

# --- ВРЕМЕННЫЙ kill switch подтверждения email ---
# AUTH_DISABLE_EMAIL_VERIFICATION=true
#
# Включайте только если SMTP физически недоступен (например, провайдер
# заблокировал исходящий 465/587 и саппорт ещё не разблокировал порт).
# В этом режиме регистрация сразу создаёт сессию и НЕ дёргает SMTP, а
# пользователи помечаются `email_verified=true` без письма. Снимать сразу
# после восстановления почты — без подтверждения email возможен «угон»
# ghost-учёток из 0002 backfill. См. docs/disable-email-verification.md.
# AUTH_DISABLE_EMAIL_VERIFICATION=false

# --- Runtime ---
NODE_ENV=production
PORT=3000
HOST=127.0.0.1
ORIGIN=https://yourdomain.tld

# Размер libuv thread-pool. По умолчанию у Node 4 — этого мало под параллельный
# bcrypt (cost=11 ≈ 100ms на хеш блокирует один воркер). Поднимаем до 16,
# чтобы пик логинов/регистраций не упирался в очередь воркеров.
UV_THREADPOOL_SIZE=16

# Trust X-Forwarded-* от Caddy (он на localhost, поэтому 1 хоп).
ADDRESS_HEADER=X-Forwarded-For
PROTOCOL_HEADER=X-Forwarded-Proto
XFF_DEPTH=1

# --- Логирование ---
# debug | info | warn | error | fatal. По умолчанию info в production.
LOG_LEVEL=info

# --- Метрики ---
# Bearer-токен для /metrics. Если пусто — endpoint открыт (надеемся на ACL Caddy).
# Сгенерировать: `openssl rand -hex 32`.
METRICS_TOKEN=
