# Caddyfile для tagcloud на ЧИСТОМ СТАТИЧЕСКОМ СЕРВЕРЕ (постоянный публичный IP).
#
# Два виртхоста:
#   * 2090.fun         — статический лендинг (раздаётся из /opt/tagcloud/landing).
#   * cloud.2090.fun   — облако тегов (SvelteKit / Node на 127.0.0.1:3000).
#
# TLS: Caddy сам выпустит и будет продлевать сертификаты Let's Encrypt по
# HTTP-01 при первом обращении к домену. Условия:
#   - на сервере постоянный публичный IP;
#   - A/AAAA-записи 2090.fun, www.2090.fun, cloud.2090.fun указывают на этот IP;
#   - порты 80 и 443 открыты снаружи (firewall/security group).
#
# Установка:
#   sudo cp deploy/Caddyfile.example /etc/caddy/Caddyfile
#   # при необходимости поменяйте домен и e-mail для ACME ниже
#   sudo systemctl reload caddy

{
	# E-mail для ACME (Let's Encrypt). Подставьте реальный ящик.
	email admin@2090.fun

	# Логи Caddy в journald (journalctl -u caddy).
	log {
		output stderr
		format console
		level INFO
	}
}

# ─────────────────────────────────────────────────────────────────────────
# Лендинг: 2090.fun — статический сайт.
# ─────────────────────────────────────────────────────────────────────────

2090.fun, www.2090.fun {
	root * /opt/tagcloud/landing
	file_server
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
		-Server
	}

	# Не отдаём случайно положенные секреты.
	@hidden path /.env /.git/* /.DS_Store
	respond @hidden 404
}

# ─────────────────────────────────────────────────────────────────────────
# Приложение: cloud.2090.fun → Node (127.0.0.1:3000).
# ─────────────────────────────────────────────────────────────────────────

cloud.2090.fun {
	# Проксируем всё на Node. WebSocket-апгрейд (ws:// → wss://) работает
	# из коробки; заголовки X-Forwarded-* нужны, чтобы getClientAddress()
	# в SvelteKit видел реальный IP клиента (rate-limit, дедуп голосов).
	reverse_proxy 127.0.0.1:3000 {
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}

		# Долгоживущие WebSocket — увеличиваем таймауты.
		transport http {
			read_timeout 1h
			write_timeout 1h
		}
	}

	# /metrics наружу не отдаём (второй слой к METRICS_TOKEN в приложении).
	@metrics path /metrics
	respond @metrics 403

	# HTTP-only security-заголовки (CSP приложение ставит само в HTML-ответе).
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
		-Server
	}

	# Health-пробы не логируем (иначе журнал заполняется).
	@healthz path /healthz /readyz
	log_skip @healthz

	@hidden path /.env /.git/*
	respond @hidden 404
}
