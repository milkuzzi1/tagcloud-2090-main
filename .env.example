# --- Postgres ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=tagcloud
POSTGRES_PASSWORD=tagcloud_dev
POSTGRES_DB=tagcloud
DATABASE_URL=postgres://tagcloud:tagcloud_dev@localhost:5432/tagcloud

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- App ---
PUBLIC_BASE_URL=http://localhost:5173
NODE_ENV=development

# --- SMTP (SendPulse) ---
# Все письма (verification, итоги опросов) уходят через SendPulse SMTP.
# Подготовка:
#   1. Зарегистрироваться на https://sendpulse.com и включить SMTP в кабинете.
#   2. Добавить и верифицировать домен отправителя (SPF/DKIM).
#   3. В Settings → SMTP взять логин (email от аккаунта) и SMTP-пароль.
#   4. Подставить логин в SMTP_USER, пароль — в SMTP_PASSWORD.
#
# По умолчанию — STARTTLS на 587. Альтернативы: 2525 (если 587 закрыт
# хостером) и 465 (implicit TLS, тогда SMTP_SECURE=true).
#
# SMTP_FROM должен быть verified sender/domain в SendPulse.
#
# В dev можно поднять MailHog вместо SendPulse:
#   docker run -d -p 1025:1025 -p 8025:8025 mailhog/mailhog
# и выставить SMTP_HOST=127.0.0.1 / SMTP_PORT=1025 / SMTP_SECURE=false /
# SMTP_USER= / SMTP_PASSWORD= (auth не нужен).
SMTP_HOST=smtp-pulse.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-account@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM="Tagcloud <noreply@yourdomain.tld>"
