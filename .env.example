# --- Postgres ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=tagcloud
POSTGRES_PASSWORD=tagcloud_dev
POSTGRES_DB=tagcloud
DATABASE_URL=postgres://tagcloud:tagcloud_dev@localhost:5432/tagcloud

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- App ---
PUBLIC_BASE_URL=http://localhost:5173
NODE_ENV=development

# --- SMTP (Gmail) ---
# Все письма (verification, итоги опросов) уходят через Gmail SMTP.
# Подготовка:
#   1. Включить 2-Step Verification на Google-аккаунте.
#   2. Создать App Password: https://myaccount.google.com/apppasswords
#      (обычный пароль не сработает — Google блокирует «less secure apps»).
#   3. Подставить адрес аккаунта в SMTP_USER и SMTP_FROM, App Password —
#      в SMTP_PASSWORD.
#
# По умолчанию — implicit TLS на 465. Альтернатива — STARTTLS на 587:
#   SMTP_PORT=587
#   SMTP_SECURE=false
#
# SMTP_FROM должен совпадать с SMTP_USER (или быть verified send-as alias
# в настройках Gmail), иначе Google молча перепишет заголовок From.
#
# В dev можно поднять MailHog вместо Gmail:
#   docker run -d -p 1025:1025 -p 8025:8025 mailhog/mailhog
# и выставить SMTP_HOST=127.0.0.1 / SMTP_PORT=1025 / SMTP_SECURE=false /
# SMTP_USER= / SMTP_PASSWORD= (auth не нужен).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-account@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM="Tagcloud <your-account@gmail.com>"
