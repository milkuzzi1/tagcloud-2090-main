# --- Postgres ---
# Set a strong, unique POSTGRES_PASSWORD. There is intentionally NO default —
# docker-compose refuses to start without it, so a weak password can't ship.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=tagcloud
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=tagcloud
DATABASE_URL=postgres://tagcloud:CHANGE_ME_strong_db_password@localhost:5432/tagcloud
# Postgres is published only on 127.0.0.1 by default. Set 0.0.0.0 only if you
# truly need remote admin access (not recommended in production).
# POSTGRES_BIND=127.0.0.1

# --- Redis ---
# Redis now requires a password (--requirepass). Keep it in both REDIS_PASSWORD
# (for the container) and inside REDIS_URL as redis://:<password>@host:port.
REDIS_PASSWORD=CHANGE_ME_strong_redis_password
REDIS_URL=redis://:CHANGE_ME_strong_redis_password@localhost:6379
# REDIS_BIND=127.0.0.1

# --- App ---
# PUBLIC_BASE_URL is REQUIRED in production: emailed verification/reset links
# are built from it. The app throws on boot if it (or ORIGIN) is unset in prod.
PUBLIC_BASE_URL=http://localhost:5173
NODE_ENV=development

# --- Metrics (Prometheus) ---
# /metrics is fail-closed: with no token it returns 404. Set a token to require
# `Authorization: Bearer <METRICS_TOKEN>`, or explicitly opt in to anonymous
# access with METRICS_ALLOW_UNAUTHENTICATED=true (only behind a trusted proxy).
# METRICS_TOKEN=
# METRICS_ALLOW_UNAUTHENTICATED=false

# --- Voting durability ---
# Default: votes are buffered in memory and flushed periodically (fast path; a
# hard crash can lose a buffer of acked votes). Set true to flush synchronously
# so a vote is only acknowledged after it is persisted (authoritative votes).
# VOTE_DURABLE_WRITES=false

# --- SMTP (SendPulse) ---
# Все письма (verification, итоги опросов) уходят через SendPulse SMTP.
# Подготовка:
#   1. Зарегистрироваться на https://sendpulse.com и включить SMTP в кабинете.
#   2. Добавить и верифицировать домен отправителя (SPF/DKIM).
#   3. В Settings → SMTP взять логин (email от аккаунта) и SMTP-пароль.
#   4. Подставить логин в SMTP_USER, пароль — в SMTP_PASSWORD.
#
# По умолчанию — STARTTLS на 587. Альтернативы: 2525 (если 587 закрыт
# хостером) и 465 (implicit TLS, тогда SMTP_SECURE=true).
#
# SMTP_FROM должен быть verified sender/domain в SendPulse.
#
# В dev можно поднять MailHog вместо SendPulse:
#   docker run -d -p 1025:1025 -p 8025:8025 mailhog/mailhog
# и выставить SMTP_HOST=127.0.0.1 / SMTP_PORT=1025 / SMTP_SECURE=false /
# SMTP_USER= / SMTP_PASSWORD= (auth не нужен).
SMTP_HOST=smtp-pulse.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-account@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM="Tagcloud <noreply@yourdomain.tld>"
