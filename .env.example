# --- Postgres ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=tagcloud
POSTGRES_PASSWORD=tagcloud_dev
POSTGRES_DB=tagcloud
DATABASE_URL=postgres://tagcloud:tagcloud_dev@localhost:5432/tagcloud

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- App ---
PUBLIC_BASE_URL=http://localhost:5173
NODE_ENV=development

# --- SMTP (локальный self-host mail-сервер) ---
# Дефолт — локальный Postfix на той же машине: app ходит через loopback,
# Postfix доверяет 127.0.0.0/8 (mynetworks) и сам подписывает DKIM + релеит
# наружу. SMTP_USER/SMTP_PASSWORD НЕ требуются — auth подключается только
# если оба заданы. Подробности по развёртыванию: deploy/mail-server.md.
#
# Если хочется сходить на чужой провайдер (Yandex/Mailgun/SES) — задайте
# SMTP_HOST/PORT/SECURE и SMTP_USER+SMTP_PASSWORD.
SMTP_HOST=127.0.0.1
SMTP_PORT=25
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Tagcloud <noreply@2090.fun>"
